# X/Twitter API Credentials (from https://developer.x.com/en/portal/dashboard)
# You need a project with OAuth 1.0a User Authentication (Read and Write)
X_API_KEY=your_api_key
X_API_SECRET=your_api_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_TOKEN_SECRET=your_access_token_secret

# LinkedIn Profile URL — the /recent-activity/all/ page will be scraped
# e.g. https://www.linkedin.com/in/johndoe
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/your-profile

# Path to Playwright persistent browser profile (with LinkedIn login session)
# Defaults to ~/.claude/playwright-profile/
PLAYWRIGHT_PROFILE_DIR=

# Maximum age of posts to consider (in days, default: 2)
MAX_POST_AGE_DAYS=2
