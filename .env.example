# X/Twitter API Credentials (from https://developer.x.com/en/portal/dashboard)
# You need a project with OAuth 1.0a User Authentication (Read and Write)
X_API_KEY=your_api_key
X_API_SECRET=your_api_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_TOKEN_SECRET=your_access_token_secret

# LinkedIn RSS Feed URL (optional, for monitor mode)
# You can use a third-party service to generate an RSS feed from a LinkedIn profile.
# Examples:
#   - https://rss.app/ (create a feed from a LinkedIn profile URL)
#   - https://feed.ly/ or similar aggregators
LINKEDIN_RSS_URL=

# Poll interval in minutes (default: 15)
POLL_INTERVAL_MINUTES=15
